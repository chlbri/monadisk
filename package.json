{
  "version": "0.0.1",
  "license": "MIT",
  "author": {
    "name": "chlbri",
    "email": "bri_lvi@icloud.com",
    "url": "https://bemedev.vercel.app"
  },
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "module": "lib/index.mjs",
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "test": "jest",
    "test-watch": "pnpm test -- --watch",
    "rollup": "rollup -c",
    "prepare": "husky install",
    "updateDependencies": "pnpm update --latest",
    "build": "rm -rf lib && pnpm run rollup ",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "eslint": "eslint \"{src/**/*,App}.{ts,tsx}\"",
    "lint": "pnpm run prettier && pnpm run eslint --fix",
    "lint-watch": "onchange --await-write-finish 5500 \"**/*\" -- pnpm run lint",
    "prepublishOnly": "pnpm run lint && pnpm run build",
    "size": "size-limit"
  },
  "husky": {
    "hooks": {
      "pre-commit": "prettier --write \"**/**.{ts,tsx,json,js,jsx,yml}\"",
      "post-commit": "a"
    }
  },
  "name": "@bemedev/monadisk",
  "size-limit": [
    {
      "path": "lib/index.js",
      "limit": "10 KB"
    },
    {
      "path": "lib/index.mjs",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@bemedev/npm-publish": "0.0.1-pnpm2",
    "@size-limit/preset-small-lib": "^8.2.4",
    "@swc/core": "^1.3.44",
    "@swc/jest": "^0.2.24",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.11",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "eslint": "^8.37.0",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "jest-extended": "^3.2.4",
    "onchange": "^7.1.0",
    "prettier": "^2.8.7",
    "rollup": "^3.20.2",
    "rollup-plugin-tsconfig-paths": "^1.4.0",
    "rollup-plugin-typescript2": "^0.34.1",
    "size-limit": "^8.2.4",
    "tslib": "^2.5.0",
    "typescript": "^5.0.3"
  }
}
